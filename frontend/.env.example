# ProcureHub Frontend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# Backend API base URL
VITE_API_URL=http://localhost:5000

# Keycloak configuration
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=procurehub
VITE_KEYCLOAK_CLIENT_ID=procurehub-frontend

# Default company ID for public vendor self-registration form.
# Set to the CompanyId of the primary tenant in the database.
VITE_DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001

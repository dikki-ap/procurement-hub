{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Database": {
    "Provider": "MariaDb",
    "ConnectionStrings": {
      "MariaDb": "Server=localhost;Port=3307;Database=procurehub;User=app;Password=secret;Allow User Variables=True;"
    }
  },
  "Keycloak": {
    "AuthServerUrl":        "http://localhost:9090/",
    "Realm":                "procurehub",
    "Resource":             "procurehub-web",
    "RequireHttpsMetadata": false
  },
  "SeaweedFS": {
    "S3Endpoint": "http://localhost:8333",
    "AccessKey":  "devaccess",
    "SecretKey":  "devsecret"
  },
  "Email": {
    "Host":        "localhost",
    "Port":        1025,
    "Username":    "",
    "Password":    "",
    "FromAddress": "noreply@procurehub.local",
    "FromName":    "ProcureHub Dev",
    "UseSsl":      false
  },
  "Pdf": {
    "FontsPath": "Assets/Fonts"
  },
  "Swagger": { "Enabled": true },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:8080"]
  }
}
